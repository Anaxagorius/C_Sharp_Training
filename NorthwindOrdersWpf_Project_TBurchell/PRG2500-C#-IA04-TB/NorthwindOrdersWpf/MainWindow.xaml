<Window x:Class="NorthwindOrdersWpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Northwind Orders Manager" Height="720" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Background="#1F2937" Padding="12">
            <DockPanel>
                <TextBlock Text="Northwind Orders" Foreground="White" FontSize="20" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <TextBox x:Name="SearchOrderIdBox" Width="140" VerticalAlignment="Center"/>
                    <Button x:Name="SearchButton" Content="Search" Click="SearchButton_Click"/>
                    <Button x:Name="RefreshButton" Content="Refresh" Click="RefreshButton_Click"/>
                    <Button x:Name="ClearButton" Content="Clear Form" Click="ClearButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
        <DataGrid Grid.Row="1" x:Name="OrdersGrid" SelectionChanged="OrdersGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="OrderID" Binding="{Binding OrderID}" IsReadOnly="True" Width="SizeToHeader"/>
                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                <DataGridTextColumn Header="OrderDate" Binding="{Binding OrderDate, StringFormat=yyyy-MM-dd}" Width="SizeToHeader"/>
                <DataGridTextColumn Header="ShipAddress" Binding="{Binding ShipAddress}" Width="2*"/>
            </DataGrid.Columns>
        </DataGrid>
        <Border Grid.Row="2" BorderThickness="1" BorderBrush="#D1D5DB" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="OrderID" Grid.Column="0" Margin="6,6,6,0"/>
                <TextBox x:Name="OrderIdBox" Grid.Column="0" Margin="6,0" IsReadOnly="True"/>
                <TextBlock Text="Customer" Grid.Column="1" Margin="6,6,6,0"/>
                <ComboBox x:Name="CustomerCombo" Grid.Column="1" DisplayMemberPath="CompanyName" SelectedValuePath="CustomerID"/>
                <TextBlock Text="Employee" Grid.Column="2" Margin="6,6,6,0"/>
                <ComboBox x:Name="EmployeeCombo" Grid.Column="2" DisplayMemberPath="FullName" SelectedValuePath="EmployeeID"/>
                <TextBlock Text="OrderDate (yyyy-MM-dd)" Grid.Column="3" Margin="6,6,6,0"/>
                <TextBox x:Name="OrderDateBox" Grid.Column="3"/>
                <TextBlock Text="ShipAddress" Grid.Column="4" Margin="6,6,6,0"/>
                <TextBox x:Name="ShipAddressBox" Grid.Column="4"/>
                <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="AddButton" Content="Add" Click="AddButton_Click"/>
                    <Button x:Name="UpdateButton" Content="Update" Click="UpdateButton_Click"/>
                    <Button x:Name="DeleteButton" Content="Delete" Click="DeleteButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
