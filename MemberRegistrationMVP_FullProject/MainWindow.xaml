
<Window x:Class="MemberRegistrationMVP.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Registration" Height="420" Width="420"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Members" Grid.Row="0" Margin="0,0,0,8">
            <ListBox x:Name="lstMembers" />
        </GroupBox>

        <GroupBox Header="Member Information" Grid.Row="1">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="First Name:"/>
                <TextBox   Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" x:Name="txtFirstName"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Last Name:"/>
                <TextBox   Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" x:Name="txtLastName"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Postal Code:"/>
                <TextBox   Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" x:Name="txtPostalCode"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Gender:"/>
                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <RadioButton x:Name="rbMale" Content="Male" Margin="0,0,12,0" IsChecked="True"/>
                    <RadioButton x:Name="rbFemale" Content="Female"/>
                </StackPanel>

                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center" Text="Member Type:"/>
                <ComboBox Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" x:Name="cmbMemberType">
                    <ComboBoxItem Content="Standard" IsSelected="True"/>
                    <ComboBoxItem Content="Student"/>
                    <ComboBoxItem Content="VIP"/>
                    <ComboBoxItem Content="Senior"/>
                </ComboBox>

                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,0,8,0" VerticalAlignment="Center" Text="Member Since:"/>
                <DatePicker Grid.Row="5" Grid.Column="1" x:Name="dpMemberSince" />
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnLoad" Content="Load" Width="70" Margin="0,0,8,0"/>
            <Button x:Name="btnSave" Content="Save" Width="70" Margin="0,0,8,0"/>
            <Button x:Name="btnUpdate" Content="Update" Width="70" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="btnDelete" Content="Delete" Width="70" Margin="0,0,8,0" Visibility="Collapsed"/>
            <Button x:Name="btnRegister" Content="Register" Width="80"/>
        </StackPanel>
    </Grid>
</Window>
