<Window x:Class="NsccSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="NSCC System - Main" Height="600" Width="980"
        WindowStartupLocation="CenterScreen" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Top blue menu bar -->
            <RowDefinition Height="Auto"/>
            <!-- Welcome + button -->
            <RowDefinition Height="Auto"/>
            <!-- Browser toolbar -->
            <RowDefinition Height="*"/>
            <!-- Browser area -->
        </Grid.RowDefinitions>

        <!-- Top blue bar with menu -->
        <Border Background="#3F51B5" Grid.Row="0">
            <DockPanel LastChildFill="True">
                <TextBlock Text="NSCC System" Foreground="White"
                           Margin="12,8" VerticalAlignment="Center"
                           FontWeight="SemiBold"/>
                <Menu DockPanel.Dock="Right" Background="Transparent" BorderThickness="0"
                      Foreground="White">
                    <MenuItem Header="About NSCC" Click="About_Click"/>
                    <MenuItem Header="Programs" Click="Programs_Click"/>
                    <MenuItem Header="Campuses and Locations" Click="Campuses_Click"/>
                    <MenuItem Header="Contact" Click="Contact_Click"/>
                </Menu>
            </DockPanel>
        </Border>

        <!-- Centered heading + button -->
        <StackPanel Grid.Row="1" Margin="0,24,0,16" HorizontalAlignment="Center">
            <TextBlock Text="Welcome to NSCC System" FontSize="28"
                       FontWeight="SemiBold" Foreground="#333"
                       HorizontalAlignment="Center" />
            <Button Content="Go to Second Window" Width="180" Height="32"
                    Margin="0,16,0,0" Click="GoToSecondWindow_Click" />
        </StackPanel>

        <!-- Browser toolbar -->
        <DockPanel Grid.Row="2" LastChildFill="True" Margin="12,0,12,6">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,8,0">
                <Button x:Name="BtnBack"    Content="⟨ Back"     Width="80" Click="BtnBack_Click" IsEnabled="False"/>
                <Button x:Name="BtnForward" Content="Forward ⟩" Width="92" Click="BtnForward_Click" IsEnabled="False"/>
                <Button x:Name="BtnRefresh" Content="⟳ Refresh" Width="92" Click="BtnRefresh_Click"/>
            </StackPanel>

            <!-- Optional: address box -->
            <TextBox x:Name="AddressBox" VerticalAlignment="Center"
                     KeyDown="AddressBox_KeyDown" />
        </DockPanel>

        <!-- Embedded WebView2 browser -->
        <Grid Grid.Row="3" Margin="12,0,12,12">
            <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6">
                <wv2:WebView2 x:Name="Browser" DefaultBackgroundColor="White"/>
            </Border>
        </Grid>
    </Grid>
</Window>
