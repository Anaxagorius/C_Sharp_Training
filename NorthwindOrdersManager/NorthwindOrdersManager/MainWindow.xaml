<Window x:Class="NorthwindOrdersManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Northwind Orders Manager"
        Height="650" Width="1000"
        Background="#1E1E2F"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Colors -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#388E3C"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2196F3"/>
        <SolidColorBrush x:Key="BgBrush" Color="#252538"/>
        <SolidColorBrush x:Key="CardBrush" Color="#2F2F45"/>
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#B0B0C0"/>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="5"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#555"/>
                    <Setter Property="Foreground" Value="#CCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox / ComboBox style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#3A3A55"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#3A3A55"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#666"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="3"/>
        </Style>

        <!-- DataGrid style -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#2C2C40"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="RowBackground" Value="#33334A"/>
            <Setter Property="AlternatingRowBackground" Value="#3B3B55"/>
            <Setter Property="GridLinesVisibility" Value="All"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#555"/>
            <Setter Property="VerticalGridLinesBrush" Value="#555"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource BgBrush}" 
                Padding="15" CornerRadius="8" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="📦 Northwind Orders Manager" 
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="   – ADO.NET + WPF" 
                           VerticalAlignment="Bottom"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="10,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Form -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}"
                    CornerRadius="8" Padding="10" Margin="0,0,10,0">
                <StackPanel>

                    <TextBlock Text="Order Details" 
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- OrderID (read-only) -->
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Order ID:"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,3"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtOrderID"
                                 IsReadOnly="True" Background="#444"
                                 ToolTip="Generated by the database"/>

                        <!-- Customer -->
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Customer:"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,3"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" x:Name="cbCustomer"
                                  DisplayMemberPath="CompanyName"
                                  SelectedValuePath="CustomerID"
                                  />

                        <!-- Employee -->
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Employee:"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,3"/>
                        <ComboBox Grid.Row="2" Grid.Column="1" x:Name="cbEmployee"
                                  DisplayMemberPath="FullName"
                                  SelectedValuePath="EmployeeID"
                                  />

                        <!-- Order Date -->
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Order Date:"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,3"/>
                        <TextBox Grid.Row="3" Grid.Column="1" x:Name="txtOrderDate"
                                 ToolTip="Enter date (e.g. 2024-01-31)"/>

                        <!-- Ship Address -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ship Address:"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,3"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="txtShipAddress"
                                 Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                        <!-- Search by OrderID -->
                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Search OrderID:"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   VerticalAlignment="Center" Margin="0,10,0,3"/>
                        <StackPanel Grid.Row="5" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBox x:Name="txtSearchOrderID" Width="100"
                                     ToolTip="Order ID to search"/>
                            <Button Content="Search" Click="BtnSearch_Click"/>
                            <Button Content="Clear" Background="{StaticResource AccentBrush}"
                                    Click="BtnClearSearch_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Add" Click="BtnAdd_Click"/>
                        <Button Content="Update" Click="BtnUpdate_Click"/>
                        <Button Content="Delete" Background="#E53935"
                                Click="BtnDelete_Click"/>
                        <Button Content="Refresh" Background="{StaticResource AccentBrush}"
                                Click="BtnRefresh_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Right: DataGrid -->
            <Border Grid.Column="1" Background="{StaticResource CardBrush}"
                    CornerRadius="8" Padding="10">
                <DockPanel>
                    <TextBlock Text="Orders" DockPanel.Dock="Top"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,10"/>

                    <DataGrid x:Name="dgOrders"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              SelectionChanged="DgOrders_SelectionChanged"
                              IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Order ID" Binding="{Binding OrderID}" Width="SizeToHeader"/>
                            <DataGridTextColumn Header="Customer" Binding="{Binding CompanyName}" Width="*"/>
                            <DataGridTextColumn Header="Employee" Binding="{Binding EmployeeName}" Width="*"/>
                            <DataGridTextColumn Header="Order Date" Binding="{Binding OrderDate}" Width="*"/>
                            <DataGridTextColumn Header="Ship Address" Binding="{Binding ShipAddress}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
